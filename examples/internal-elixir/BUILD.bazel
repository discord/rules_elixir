load("@rules_elixir//:defs.bzl", "elixir_app", "ex_unit_test", "mix_release", "mix_library")
load("@rules_erlang//:escript.bzl", "escript_archive")
load("@rules_erlang//:erlang_erts_layer.bzl", "erlang_erts_layer")
load(":container.bzl", "elixir_container_image")

